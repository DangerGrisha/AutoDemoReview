# Copy this file to .env and fill in your key. .env is read by src/coach.py
# (Layer 6) via python-dotenv; the key is never hardcoded in source.
ANTHROPIC_API_KEY=sk-ant-...

# ---- Web app (web/) ----
# REQUIRED: signs session cookies. Use a long random string, e.g.
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=MEOWWWWWWWWWWWWWWWWWWWWWWWWWWWWW

# Public base URL the browser uses to reach the app; builds the Steam OpenID
# return_to/realm. Use the host's LAN IP (e.g. http://192.168.1.20:8000) so
# friends on the network can log in. Must match where the app is actually served.
BASE_URL=http://localhost:8000

# OPTIONAL: Steam Web API key -> real display names + avatars.
# Get one free at https://steamcommunity.com/dev/apikey
# If unset, users are shown by their SteamID64 (login still works).
STEAM_API_KEY=

# OPTIONAL overrides (sensible defaults if omitted)
# APP_DB_PATH=web/data/app.db
# MAX_UPLOAD_MB=800
# PARSE_CONCURRENCY=1
# HOST=0.0.0.0
# PORT=8000
